# ============================================================
# Energize AI Coaching Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ─── PostgreSQL ──────────────────────────────────────────────
# Connection string for the FastAPI backend (SQLAlchemy / asyncpg)
DATABASE_URL=postgresql+asyncpg://energize:changeme@localhost:5432/energize

# PostgreSQL individual credentials (used by docker-compose and K8s)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=energize
POSTGRES_USER=energize
POSTGRES_PASSWORD=changeme           # min 16 chars in production


# ─── Keycloak ────────────────────────────────────────────────
# Base URL of the Keycloak server (no trailing slash)
KEYCLOAK_URL=http://localhost:8080
# Realm name (must match realm-export.json)
KEYCLOAK_REALM=energize
# Backend (confidential) client credentials
KEYCLOAK_CLIENT_ID=energize-backend
KEYCLOAK_CLIENT_SECRET=changeme      # set in Keycloak → Clients → Credentials
# Admin credentials (used for realm management via Keycloak Admin REST API)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme

# ─── LLM Provider ───────────────────────────────────────────────────────────
# Active provider: openai | anthropic | google_genai | azure_openai | mistralai
LLM_PROVIDER=openai
# Model name for the selected provider
# OpenAI examples  : gpt-4o, gpt-4o-mini, gpt-4-turbo
# Anthropic examples: claude-3-5-sonnet-20241022, claude-3-haiku-20240307
# Google examples   : gemini-1.5-pro, gemini-1.5-flash
# Mistral examples  : mistral-large-latest, mistral-small-latest
LLM_MODEL=gpt-4o-mini
# API key for the selected provider
LLM_API_KEY=<your-api-key>
# Temperature for response generation (0.0 – 2.0)
LLM_TEMPERATURE=0.7
# Maximum tokens per LLM response
LLM_MAX_TOKENS=2048
# Enable streaming responses
LLM_STREAMING=true
# Deprecated — OPENAI_API_KEY is still accepted as a fallback when LLM_PROVIDER=openai.
# Migrate to LLM_API_KEY.
# OPENAI_API_KEY=<your-openai-key>

# ─── Embeddings (pgvector) ───────────────────────────────────────────────────
# Embedding model — auto-resolved from LLM_PROVIDER when left blank.
# openai / azure_openai : text-embedding-3-small (1536 dims)
# google_genai          : text-embedding-004     (768 dims)
# mistralai             : mistral-embed          (1024 dims)
# anthropic             : falls back to OpenAI   (1536 dims)
EMBEDDING_MODEL=
# Must match the model's output dimension. Run 'alembic upgrade head' after changing.
EMBEDDING_DIMENSIONS=1536

# ─── OpenTelemetry ───────────────────────────────────────────────────────────
# Service name reported in all traces and metrics
OTEL_SERVICE_NAME=energize-backend
# Set to false to fully disable OTel instrumentation
OTEL_ENABLED=true
# gRPC OTLP endpoint — leave blank for console-only (stdout) export
# Example: OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_ENDPOINT=
# How often metrics are flushed to exporters (milliseconds)
OTEL_EXPORT_INTERVAL_MILLIS=10000
# WARNING: set true only in dev — logs full prompt/completion content (may expose PII)
OTEL_INCLUDE_PROMPT_CONTENT=false

# ─── Backend (FastAPI) ───────────────────────────────────────
# Application environment: development | staging | production
APP_ENV=development
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Secret key for signing internal JWTs / sessions (generate with: openssl rand -hex 32)
APP_SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
# Backend host and port (uvicorn)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Host-side port mappings for docker-compose (container stays on its default internal port)
BACKEND_HOST_PORT=8001
KEYCLOAK_PORT=8080
MCP_PORT=9000
FRONTEND_PORT=3000
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://coaching.energize.com

# ─── Frontend (Next.js) ──────────────────────────────────────
# Public variables are embedded at build time (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=energize
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=energize-frontend
# Feature flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_DEBUG_PANEL=true   # set to false in production

# ─── Email (SMTP) ────────────────────────────────────────────
# Used by Keycloak for password-reset and verification emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@energize.com
SMTP_PASSWORD=changeme
SMTP_FROM=noreply@energize.com
SMTP_FROM_NAME=Energize AI Coaching
SMTP_STARTTLS=true
SMTP_SSL=false

# ─── Redis (optional — for caching / rate limiting) ──────────
REDIS_URL=redis://localhost:6379/0

# ─── Observability ───────────────────────────────────────────
# Sentry DSN for error tracking (leave blank to disable)
SENTRY_DSN=
# OpenTelemetry exporter endpoint (leave blank to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=
